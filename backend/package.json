{
  "name": "chat-backend",
  "version": "1.0.0",
  "description": "Private Connection Platform - Backend Server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "websocket": "node src/websocket/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "psql $DATABASE_URL < database/schema.sql"
  },
  "keywords": [
    "chat",
    "messaging",
    "real-time",
    "websocket",
    "journal",
    "goals",
    "memories"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.1.2",
    "socket.io": "^4.7.2",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "axios": "^1.6.2",
    "moment": "^2.29.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
